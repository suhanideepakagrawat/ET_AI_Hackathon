# Copy to `.env` (git-ignored) and fill in. ALL OPTIONAL — the advisory API runs
# fully without any key (deterministic templates + Hindi phrase table).
#
# Groq is OpenAI-compatible and free/fast. Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Voice (optional) — a real neural voice for the citizen bot. Without any of these
# the bot falls back to the browser's built-in speech. ElevenLabs speaks EN + Hindi
# (https://elevenlabs.io); Deepgram Aura is an English fallback (https://deepgram.com).
ELEVENLABS_API_KEY=
ELEVEN_VOICE_ID=EXAVITQu4vr4xnSDxMaL
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-athena-en
